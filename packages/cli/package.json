{
  "name": "bahrawy-calendar-cli",
  "version": "0.1.0",
  "description": "CLI for scaffolding Bahrawy Calendar UI components into your project",
  "bin": {
    "bahrawy-calendar": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^20.0.0"
  }
}
