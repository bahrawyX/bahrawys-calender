# ─── Lumina Calendar — External Integrations ─────────────────────────────
#
# Copy this file to `.env.local` and fill in your credentials.
# Only the providers you configure will appear as "Connect" options.
#
# ── Google Calendar ──────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add http://localhost:3000/api/integrations/google/callback as an
#    Authorized redirect URI
# 4. Enable the Google Calendar API in your project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft Outlook ────────────────────────────────────────────────────
# 1. Go to https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# 2. Register a new application (Accounts in any org + personal)
# 3. Add http://localhost:3000/api/integrations/microsoft/callback as a
#    Redirect URI (Web platform)
# 4. Create a client secret under Certificates & secrets
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# ── Security ─────────────────────────────────────────────────────────────
# Used to encrypt OAuth tokens stored in HTTP-only cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_SECRET=change-me-to-a-random-64-hex-string

# ── App URL ──────────────────────────────────────────────────────────────
# Public URL of your deployment (used for OAuth callback URLs).
# In development this is usually http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000
